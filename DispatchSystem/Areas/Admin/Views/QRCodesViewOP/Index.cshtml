                    "bServerSide": true,
                    "bProcessing": true,
                    "bSearchable": true,
                    "order": [[0, 'asc']],
                    pageLength: 50,
                    lengthMenu: [
                        [10, 25, 50, -1],
                        [10, 25, 50, 'All']
